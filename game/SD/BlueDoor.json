        [
            [
                "Dialogue"
            ],
            [
                "You have chosen the Blue door"
            ],
            [
                "You are in andless row of apartments"
            ],
            [
                "Each represent one of our asigments grades"
            ],
            [
                "Yours is like 0"
            ],
            [
                "Who said that?"
            ],
            [
                "The splendorman, Nice to meet you [tn]"
            ],
            [
                "H- How do you know my name?"
            ],
            [
                "I know the names of many"
            ],
            [
                "But, but we never met!"
            ],
            [
                "Oh we did Darling, but you can't remember"
            ],
            [
                "Don't you remember when we flashed across the stars, and you looked at my eyes with whimsy smiles?"
            ],
            [
                "I.. I don't thin-"
            ],
            [
                "Don't make a fool of yourself, Darling. We can start over, trust in me!"
            ],
            [
                "Hey. I really don't think i should be here"
            ],
            [
                "NO! Darling!"
            ],
            [
                "Please, listen to me. You know you are happy with me, please!"
            ],
            [
                "Let me go! I want to go back!"
            ],
            [
                "You dont get it love! I need you. Please!"
            ],
            [
                "I told you to get away from me!"
            ],
            [
                "HEY! NO... Stop it now! LOVE!"
            ],
            [
                "You won't go away love, you need me, and I need you."
            ],
            [
                "And you know there is no love outside, nowhere but here and no one but me!"
            ],
            [
                "Remember who hurt you! The gay slenderman!"
            ],
            [
                "And all the freak things he did to you, Darling! Please!"
            ],
            [
                "I've done nothing but professing my love!"
            ],
            [
                "And outside!.... There!... There is no love!"
            ],
            [
                "An eerie sensation of melancholy breezes you when you remember dark days"
            ],
            [
                "You... You're right..."
            ],
            [
                "Come hug me love.... We're meant to be together darling."
            ],
            [
                "y- yes dear..."
            ],
            [
                "And that's how I stayed"
            ],
            [
                "..........................."
            ],
            [
                "three weeks later he cheated on me with gay slenderman."
